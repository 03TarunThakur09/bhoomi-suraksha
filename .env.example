# Bhoomi Suraksha — Environment Variables Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# Google Cloud (for Vision OCR)
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/google_cred.json

# Database
DATABASE_URL=sqlite+aiosqlite:///./propverify.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bhoomi

# JWT Auth
JWT_SECRET_KEY=generate-a-strong-random-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# App Settings
APP_ENV=development
APP_DEBUG=true
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
